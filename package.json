{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build && vite build --ssr",
        "dev": "vite",
        "serve:web": "php artisan serve --host=0.0.0.0 --port=8001",
        "serve:mobile": "npm --prefix mobile run start:lan",
        "checkpoint:info": "node -e \"console.log('Web URL: http://127.0.0.1:8001 (do not use http://0.0.0.0:8001)')\"",
        "checkpoint:start": "npm run checkpoint:info && concurrently -k -n WEB,VITE,MOBILE -c \"yellow,cyan,green\" \"npm run serve:web\" \"npm run dev\" \"npm run serve:mobile\"",
        "ui:smoke": "playwright test"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@playwright/test": "^1.55.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/server-renderer": "^3.4.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.2.1",
        "vite": "^7.0.7",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@fortawesome/fontawesome-free": "^7.2.0",
        "highcharts": "^12.4.0"
    }
}
